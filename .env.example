# DecentGPU — Environment Variables Template
# Copy to .env and fill in real values:
#   cp .env.example .env && nano .env
# This file is SAFE to commit. Never commit .env

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://decentgpu:CHANGE_ME@postgres:5432/decentgpu
POSTGRES_DB=decentgpu
POSTGRES_USER=decentgpu
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_MINIMUM_32_CHARS_RANDOM_STRING
ADMIN_EMAIL=admin@gpu.candeniz.me
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Bootstrap (fill after first deploy — see COOLIFY_SETUP.md) ───────────────
BOOTSTRAP_PEER_ID=FILL_AFTER_FIRST_DEPLOY

# ── Master ────────────────────────────────────────────────────────────────────
MASTER_API_ADDR=0.0.0.0:8888
MASTER_P2P_TCP_ADDR=/ip4/0.0.0.0/tcp/9010
MASTER_WS_PORT=9012
MASTER_BOOTSTRAP_ADDR=/ip4/bootstrap/tcp/9000
MASTER_BOOTSTRAP_PEER_ID=FILL_AFTER_FIRST_DEPLOY
MASTER_PUBLIC_IP=gpu.candeniz.me
MASTER__STORAGE_PATH=/data/job-files
MASTER__JWT_SECRET=CHANGE_ME_MINIMUM_32_CHARS_RANDOM_STRING
MASTER_KEYPAIR_PATH=/data/master.keypair

# ── Bootstrap node ────────────────────────────────────────────────────────────
BOOTSTRAP_PORT=9000
BOOTSTRAP_WS_PORT=9002
BOOTSTRAP_KEYPAIR_PATH=/data/bootstrap.keypair
BOOTSTRAP_HEALTH_PORT=9001

# ── Cloudflare Tunnel ─────────────────────────────────────────────────────────
# Get from: Zero Trust → Networks → Tunnels → your tunnel → token
CLOUDFLARE_TUNNEL_TOKEN=PASTE_YOUR_FULL_TOKEN_HERE

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://gpu.candeniz.me
NEXT_PUBLIC_WS_URL=wss://gpu.candeniz.me
