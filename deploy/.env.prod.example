# DecentGPU — Production Environment Variables
# Copy to .env and fill in real values before running docker compose.
#
# Usage:
#   cp deploy/.env.prod.example deploy/.env
#   nano deploy/.env
#   cd deploy && docker compose -f docker-compose.prod.yml up -d

# ── PostgreSQL ──────────────────────────────────────────────────────────────────
POSTGRES_DB=decentgpu
POSTGRES_USER=decentgpu
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# ── Auth ────────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_random_hex_64_chars

# ── Admin account (created on first boot) ──────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME_admin_password

# ── Bootstrap node ─────────────────────────────────────────────────────────────
# Obtain after first run with: ./deploy/init-bootstrap-id.sh
BOOTSTRAP_PEER_ID=FILL_IN_AFTER_FIRST_RUN

# ── Cloudflare Tunnel ──────────────────────────────────────────────────────────
# Create a tunnel in Zero Trust → Access → Tunnels, copy the token here.
# Configure ingress rules in the dashboard:
#   gpu.candeniz.me              → http://nginx:8080
#   ws-bootstrap.gpu.candeniz.me → http://bootstrap:9002
#   ws-master.gpu.candeniz.me    → http://master:9012
CLOUDFLARE_TUNNEL_TOKEN=FILL_IN_FROM_ZERO_TRUST_DASHBOARD
